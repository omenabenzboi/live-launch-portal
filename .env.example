# =========================================================================
# Omena Codex — environment template
# Copy to .env. Public (VITE_*) values are bundled into the browser.
# Server-only secrets are read inside server functions / server routes only.
# =========================================================================

# --- Lovable Cloud (auto-populated when Cloud is enabled) ---
# Public, safe to expose in the browser:
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
# Server-only mirrors (do NOT prefix with VITE_):
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
# Service role is provisioned by Lovable Cloud — never expose this to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# --- AI gateway (auto-provisioned by Lovable) ---
LOVABLE_API_KEY=

# --- Optional: legacy fallback when running against a different backend ---
VITE_API_BASE_URL=
VITE_WS_URL=

# --- Agent daemon (Milestone 3) ---
# When you deploy omena-agentd on a server, configure the host here per-server
# via the Settings → Servers screen rather than .env. .env values below are
# fallbacks only.
AGENT_DAEMON_URL=
AGENT_DAEMON_TOKEN=

# --- Provider keys (Milestone 2 wires the UI; until then these are unused) ---
# Keys added via Settings → Providers are stored encrypted in Lovable Cloud.
# These env values are only used if no provider record matches and the app
# falls back to a single hardcoded key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=

# --- Webhook signing secret (for cron jobs hitting /api/public/*) ---
WEBHOOK_SECRET=
